# Copy to .env and fill in values — NEVER commit .env

# PostgreSQL
POSTGRES_USER=passguard
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=passguard

# Redis
REDIS_PASSWORD=change_me_redis_password

# Entitlement service — 32+ char secret for HMAC-SHA256 QR token signing
# Generate with: openssl rand -hex 32
HMAC_SECRET=change_this_in_production_32chars_minimum_length!!

# QR token TTL in seconds (PCI DSS: short-lived tokens)
QR_TOKEN_TTL_SECONDS=60
